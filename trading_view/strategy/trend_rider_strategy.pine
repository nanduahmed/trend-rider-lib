//@version=6
// =============================================================================
// Trend Rider – Strategy
// Design Reference: trend_rider_lib/design.md
//
// Entry  : First daily buy-zone green candle while STATE_UPTREND is active.
// Exit   : Trade Manager – fixed Target, fixed Stop-Loss, Trailing Stop-Loss.
// One open trade at a time (Trade Manager gate).
// =============================================================================
strategy(
     title                = "Trend Rider Strategy",
     shorttitle           = "TR-STR",
     overlay              = true,
     max_labels_count     = 500,
     max_boxes_count      = 120,
     max_lines_count      = 120,
     initial_capital      = 100000,
     default_qty_type     = strategy.percent_of_equity,
     default_qty_value    = 10,
     commission_type      = strategy.commission.percent,
     commission_value     = 0.1,
     slippage             = 2,
     calc_on_every_tick   = false)

// =============================================================================
// INPUT GROUPS
// =============================================================================
rulesGroup      = "Rules"
visibilityGroup = "Visibility"
colorsGroup     = "Colors"
tableGroup      = "Table"
tmGroup         = "Trade Manager"

// ── Trend Rules ──────────────────────────────────────────────────────────────
warmupWeeks        = input.int(25,   "Warm-up weeks",            minval=1,                         group=rulesGroup)
weeklyEmaLen       = input.int(21,   "Weekly EMA length",        minval=1,                         group=rulesGroup)
dailyFastLen       = input.int(34,   "Daily fast EMA length",    minval=1,                         group=rulesGroup)
dailySlowLen       = input.int(55,   "Daily slow EMA length",    minval=1,                         group=rulesGroup)
qualificationWeeks = input.int(40,   "Qualification weeks",      minval=1,                         group=rulesGroup)
minStrengthPct     = input.float(70.0,"Minimum strength %",      minval=0.0, maxval=100.0, step=0.5, group=rulesGroup)
buyZoneMax         = input.float(1.05,"Buy zone upper multiplier",minval=1.0, step=0.01,            group=rulesGroup)
breakThreshold     = input.float(0.90,"Break threshold multiplier",minval=0.1, maxval=1.0, step=0.01, group=rulesGroup)
requireQualified   = input.bool(true, "Require TR-Qualified before entry", group=rulesGroup)

// ── Trade Manager ─────────────────────────────────────────────────────────────
tm_targetPct = input.float(15.0, "Target %",          minval=0.1, step=0.5,  group=tmGroup)
tm_slPct     = input.float(7.0,  "Stop Loss %",       minval=0.1, step=0.5,  group=tmGroup)
tm_tslPct    = input.float(5.0,  "Trailing SL %",     minval=0.1, step=0.5,  group=tmGroup)
tm_tslAct    = input.float(3.0,  "TSL Activation % (profit before TSL arms)", minval=0.0, step=0.5, group=tmGroup)

// ── Visibility ────────────────────────────────────────────────────────────────
showWeeklyEma     = input.bool(true,  "Show weekly EMA",           group=visibilityGroup)
showDailyEmas     = input.bool(true,  "Show daily EMAs",           group=visibilityGroup)
showBuyZone       = input.bool(true,  "Show buy zone",             group=visibilityGroup)
showTrendStarts   = input.bool(true,  "Show trend starts",         group=visibilityGroup)
showTrendEnds     = input.bool(true,  "Show trend ends",           group=visibilityGroup)
showConfirmations = input.bool(true,  "Show daily confirmations",  group=visibilityGroup)
showSummaryLabels = input.bool(true,  "Show trend summary labels", group=visibilityGroup)
showTrendTable    = input.bool(true,  "Show trend table",          group=visibilityGroup)
showTMTable       = input.bool(true,  "Show TM status table",      group=visibilityGroup)

// ── Colors ────────────────────────────────────────────────────────────────────
weeklyEmaColor    = input.color(color.rgb(0, 88, 255),         "Weekly EMA21",       group=colorsGroup)
dailyFastColor    = input.color(color.rgb(0, 100, 0),          "Daily EMA34",        group=colorsGroup)
dailySlowColor    = input.color(color.rgb(220, 0, 0),          "Daily EMA55",        group=colorsGroup)
startColor        = input.color(color.rgb(0, 150, 80),         "Trend start marker", group=colorsGroup)
endColor          = input.color(color.rgb(220, 40, 40),        "Trend end marker",   group=colorsGroup)
confirmationColor = input.color(color.rgb(145, 70, 190),       "Confirmation marker",group=colorsGroup)
buyZoneColor      = input.color(color.new(color.rgb(0,170,90),75),"Buy zone fill",   group=colorsGroup)
buyZoneExitColor  = input.color(color.new(#f63f3f, 75),        "Exit zone fill",     group=colorsGroup)
tableHeaderColor  = input.color(color.rgb(35, 35, 35),         "Table header",       group=colorsGroup)
tableTextColor    = input.color(color.white,                   "Table text",         group=colorsGroup)
tableBodyColor    = input.color(color.new(color.rgb(35,35,35),12),"Table body",      group=colorsGroup)

// ── Table ─────────────────────────────────────────────────────────────────────
tablePositionInput = input.string("Top Right", "Trend table position",
     options=["Top Right","Top Left","Bottom Right","Bottom Left"], group=tableGroup)
tmTablePosInput    = input.string("Bottom Right", "TM table position",
     options=["Top Right","Top Left","Bottom Right","Bottom Left"], group=tableGroup)
tableTextSizeInput = input.string("Small", "Table text size",
     options=["Tiny","Small","Normal"], group=tableGroup)
maxStoredTrends    = input.int(8, "Recent trends in table", minval=1, maxval=20, group=tableGroup)

// =============================================================================
// UTILITY FUNCTIONS
// =============================================================================
f_table_position(value) =>
    switch value
        "Top Left"     => position.top_left
        "Bottom Right" => position.bottom_right
        "Bottom Left"  => position.bottom_left
        => position.top_right

f_text_size(value) =>
    switch value
        "Tiny"   => size.tiny
        "Normal" => size.normal
        => size.small

f_bool(value)     => value ? "Y" : "N"
f_date(ts)        => na(ts) ? "-" : str.format_time(ts, "yyyy-MM-dd")
f_pct(v)          => str.tostring(v, "#.##") + "%"

f_strength_class(strength) =>
    strength < 70.0  ? "Weak"       :
     strength < 80.0 ? "Developing" :
     strength < 90.0 ? "Moderate"   :
     strength < 100.0 ? "Strong"    : "Super"

f_summary_text(id, status, startTs, endTs, weeks, strength, strengthClass, highValue, lowValue, buyZone, qualified, classification) =>
    "Trend "     + str.tostring(id)                                    +
     "\nStatus: " + status                                              +
     "\nStart: "  + f_date(startTs)                                     +
     "\nEnd: "    + f_date(endTs)                                       +
     "\nWeeks: "  + str.tostring(weeks)                                 +
     "\nStrength: "+ str.tostring(strength, "#.##") + "% (" + strengthClass + ")" +
     "\nHigh: "   + str.tostring(highValue, format.mintick)             +
     "\nLow: "    + str.tostring(lowValue,  format.mintick)             +
     "\nBuy Zone: "+ f_bool(buyZone)                                    +
     "\nQualified:"+ f_bool(qualified)                                  +
     "\nClass: "  + classification

f_draw_label(x, y, txt, tip, style, clr) =>
    if barstate.isconfirmed
        label.new(x=x, y=y, text=txt, xloc=xloc.bar_time, yloc=yloc.price,
             style=style, color=clr, textcolor=color.white, size=size.small, tooltip=tip)

f_note_suffix(note) => note == "" ? "" : "\nNote: " + note

f_store_trend_at(ids, statuses, starts, ends, weeksArr, strengths, classes, buyZones, qualifiedArr,
                 idx, id, status, startTs, endTs, weeks, strength, strengthClass, buyZone, isQualified) =>
    array.set(ids,          idx, id)
    array.set(statuses,     idx, status)
    array.set(starts,       idx, startTs)
    array.set(ends,         idx, endTs)
    array.set(weeksArr,     idx, weeks)
    array.set(strengths,    idx, strength)
    array.set(classes,      idx, strengthClass)
    array.set(buyZones,     idx, buyZone)
    array.set(qualifiedArr, idx, isQualified)

// =============================================================================
// DAILY CONTEXT (MTF helper – evaluated inside request.security)
// =============================================================================
f_daily_context() =>
    _ema21          = ta.ema(close, 21)
    _ema34          = ta.ema(close, dailyFastLen)
    _ema55          = ta.ema(close, dailySlowLen)
    _crossFastSlow  = ta.crossover(_ema34, _ema55)
    _crossCloseEma21= ta.crossover(close, _ema21)
    _barsSinceCross = ta.barssince(_crossFastSlow)
    _barsSinceWeek  = ta.barssince(ta.change(time("W")) != 0)
    _crossWithinWeek= not na(_barsSinceCross) and (na(_barsSinceWeek) or _barsSinceCross <= _barsSinceWeek)
    _crossTime      = _crossWithinWeek ? ta.valuewhen(_crossFastSlow, time,  0) : int(na)
    _crossPrice     = _crossWithinWeek ? ta.valuewhen(_crossFastSlow, close, 0) : na
    [close, time, open, _ema21, _ema34, _ema55, _crossFastSlow, _crossCloseEma21,
     _crossWithinWeek, _crossTime, _crossPrice]

// =============================================================================
// MTF DATA LAYER  (non-repainting)
// =============================================================================
[weeklyClose, weeklyHigh, weeklyLow, weeklyTime, weeklyEma, weeklyOpen, weeklyBarIndex] =
     request.security(syminfo.tickerid, "W",
         [close, high, low, time_close, ta.ema(close, weeklyEmaLen), open, bar_index],
         barmerge.gaps_off, barmerge.lookahead_off)

[dailyClose, dailyTime, dailyOpen,
 dailyEma21, dailyEma34, dailyEma55,
 dailyCrossFastSlow, dailyCrossCloseEma21,
 dailyCrossFastSlowWithinWeek, dailyCrossFastSlowTime, dailyCrossFastSlowPrice] =
     request.security(syminfo.tickerid, "D",
         f_daily_context(),
         barmerge.gaps_off, barmerge.lookahead_off)

// =============================================================================
// DERIVED FLAGS / ZONE CALCS
// =============================================================================
var int weeklyMarkerTime = na
if ta.change(weeklyTime) != 0
    weeklyMarkerTime := timeframe.isweekly ? weeklyTime[1] : weeklyTime

newWeek              = ta.change(weeklyTime) != 0
newDailyBar          = timeframe.isdaily ? barstate.isconfirmed : ta.change(dailyTime) != 0
newDailyFastSlowCross= timeframe.isweekly ? newWeek and dailyCrossFastSlowWithinWeek
                                          : newDailyBar and dailyCrossFastSlow
newDailyEma21Cross   = newDailyBar and dailyCrossCloseEma21

pastWarmup           = weeklyBarIndex >= warmupWeeks
aboveWeeklyEma       = weeklyClose > weeklyEma
buyZoneGreenCandle   = weeklyClose > weeklyOpen
inBuyZone            = aboveWeeklyEma and weeklyClose <= weeklyEma * buyZoneMax and buyZoneGreenCandle
inAboveBuyZone       = weeklyClose > weeklyEma * buyZoneMax
trendBreak           = weeklyClose < weeklyEma * breakThreshold

buyZoneTop    = weeklyEma * buyZoneMax
buyZoneBottom = weeklyEma * breakThreshold

// Daily buy-zone green-candle detection (runs on the current chart bar)
dailyGreenCandle   = dailyClose > dailyOpen
dailyInBuyZone     = dailyClose > weeklyEma and dailyClose <= weeklyEma * buyZoneMax and dailyGreenCandle

// =============================================================================
// FSM CONSTANTS / STATE
// =============================================================================
var int STATE_WARMUP     = 0
var int STATE_OBSERVING  = 1
var int STATE_UPTREND    = 2
var int STATE_DOWNTREND  = 3
var int STATE_RECOVERING = 4

var int state = STATE_WARMUP

// Trend lifecycle
var bool   tr_qualified     = false
var int    trendId          = 0
var int    trendWeeks       = 0
var int    closesAbove      = 0
var int    closesBelow      = 0
var int    trendStartTime   = na
var float  trendHigh        = na
var float  trendLow         = na
var string currentClassification = "UNQUALIFIED"
var label  currentTrendLabel     = na

// Evidence
var int   firstBuyZoneTime             = na
var float firstBuyZonePrice            = na
var int   dailyPositiveCrossoverTime   = na
var float dailyPositiveCrossoverPrice  = na
var int   recoveryConfirmedWeekTime    = na
var float maxProfitPct                 = 0.0

// Signal-dedup guards
var bool buySignalEmitted          = false
var bool qualifiedSignalEmitted    = false
var bool momentumSignalEmitted     = false
var bool dailyCrossoverConfirmed   = false
var bool momentumEntryPendingLabel = false
var bool positiveCrossoverLabelPending   = false
var bool recoveryPositiveCrossoverNote   = false

// Signal event flags
var bool sigUptrendStart  = false
var bool sigReentry       = false
var bool sigMomentumEntry = false
var bool sigDowntrendStart= false
var bool sigEmaCrossover  = false
var bool sigTrQualified   = false

// Performance / table cache
var bool   tableNeedsRebuild   = true
var float  currentStrength     = 0.0
var string currentStrengthClass= "Weak"
var string summaryCache        = ""

// =============================================================================
// CIRCULAR BUFFER  (O(1))
// =============================================================================
var array<int>    trendIds       = array.new_int(maxStoredTrends,    0)
var array<string> trendStatuses  = array.new_string(maxStoredTrends, "")
var array<int>    trendStarts    = array.new_int(maxStoredTrends,    na)
var array<int>    trendEnds      = array.new_int(maxStoredTrends,    na)
var array<int>    trendWeeksArr  = array.new_int(maxStoredTrends,    0)
var array<float>  trendStrengths = array.new_float(maxStoredTrends,  0.0)
var array<string> trendClasses   = array.new_string(maxStoredTrends, "")
var array<bool>   trendBuyZones  = array.new_bool(maxStoredTrends,   false)
var array<bool>   trendQualified = array.new_bool(maxStoredTrends,   false)
var int trendBufferIdx = 0

// =============================================================================
// TRADE MANAGER STATE
// =============================================================================
var bool  tm_inTrade        = false       // one-trade gate
var float tm_entryPrice     = na          // recorded entry fill price
var float tm_targetPrice    = na          // fixed target
var float tm_slPrice        = na          // fixed stop-loss
var float tm_tslHighest     = na          // highest close since entry (TSL tracker)
var float tm_tslPrice       = na          // current trailing stop level
var bool  tm_tslArmed       = false       // TSL arms after tm_tslAct% profit
var int   tm_entryBar       = na          // bar_index of entry
var bool  tm_firstBuyZoneHit= false       // latch: fires once per trend cycle

// =============================================================================
// UI – PLOTS / FILLS
// =============================================================================
plot(showWeeklyEma ? weeklyEma : na,
     "Weekly EMA21", weeklyEmaColor, 2)
plot(showDailyEmas and not timeframe.isweekly ? dailyEma34 : na,
     "Daily EMA34", dailyFastColor, 1)
plot(showDailyEmas and not timeframe.isweekly ? dailyEma55 : na,
     "Daily EMA55", dailySlowColor, 1)

buyZoneUpperPlot = plot(showBuyZone ? buyZoneTop    : na, "Buy Zone Upper",
     color.new(startColor, 80), linewidth=2)
buyZoneMidPlot   = plot(weeklyEma,                        "EMA21",
     color.new(startColor, 80), linewidth=1)
buyZoneLowerPlot = plot(showBuyZone ? buyZoneBottom : na, "Buy Zone Lower",
     color.new(endColor, 80),   linewidth=1)

fill(buyZoneUpperPlot, buyZoneMidPlot,  color=showBuyZone ? buyZoneColor     : na, title="Buy Zone Fill")
fill(buyZoneLowerPlot, buyZoneMidPlot,  color=showBuyZone ? buyZoneExitColor : na, title="Exit Zone Fill")
bgcolor(showBuyZone and inBuyZone ? color.new(buyZoneColor, 90) : na,
     title="Active Buy Zone Background")

// TSL line plot
plot(tm_inTrade and tm_tslArmed ? tm_tslPrice : na,
     "Trailing Stop", color.orange, 1, plot.style_linebr)
plot(tm_inTrade ? tm_targetPrice : na,
     "Target",        color.lime,   1, plot.style_linebr)
plot(tm_inTrade ? tm_slPrice     : na,
     "Stop Loss",     color.red,    1, plot.style_linebr)

// =============================================================================
// DAILY EVIDENCE / SIGNAL PREP
// =============================================================================
sigUptrendStart   := false
sigReentry        := false
sigMomentumEntry  := false
sigDowntrendStart := false
sigEmaCrossover   := false
sigTrQualified    := false

if newDailyEma21Cross and state == STATE_OBSERVING
    dailyPositiveCrossoverTime  := int(dailyTime)
    dailyPositiveCrossoverPrice := dailyEma21

if newDailyFastSlowCross
    sigEmaCrossover := true
    if state == STATE_DOWNTREND or state == STATE_RECOVERING
        if not dailyCrossoverConfirmed
            dailyPositiveCrossoverTime  := timeframe.isweekly ? int(dailyCrossFastSlowTime) : int(dailyTime)
            dailyPositiveCrossoverPrice := timeframe.isweekly ? dailyCrossFastSlowPrice      : dailyClose
            if state == STATE_RECOVERING
                recoveryConfirmedWeekTime := weeklyMarkerTime
        dailyCrossoverConfirmed    := true
        positiveCrossoverLabelPending := true
        if tr_qualified
            momentumEntryPendingLabel := true

// =============================================================================
// FSM LAYER  (weekly transitions)
// =============================================================================
if newWeek and not na(weeklyEma)
    prevState = state

    // ── WARMUP ──────────────────────────────────────────────────────────────
    if state == STATE_WARMUP
        if pastWarmup
            state := STATE_OBSERVING

    // ── OBSERVING ────────────────────────────────────────────────────────────
    else if state == STATE_OBSERVING
        if aboveWeeklyEma
            trendId    += 1
            state       := STATE_UPTREND
            trendWeeks  := 0
            closesAbove := 0
            closesBelow := 0
            trendStartTime  := weeklyMarkerTime
            trendHigh       := weeklyHigh
            trendLow        := weeklyLow
            firstBuyZoneTime  := inBuyZone ? weeklyMarkerTime : na
            firstBuyZonePrice := inBuyZone ? weeklyClose      : na
            maxProfitPct      := 0.0
            buySignalEmitted  := false
            dailyCrossoverConfirmed     := false
            momentumSignalEmitted       := false
            positiveCrossoverLabelPending := false
            recoveryPositiveCrossoverNote := false
            dailyPositiveCrossoverTime  := na
            dailyPositiveCrossoverPrice := na
            qualifiedSignalEmitted      := tr_qualified
            sigUptrendStart             := true
            tm_firstBuyZoneHit          := false   // reset TM latch for new trend

            if showTrendStarts
                _tip = f_summary_text(trendId, "Started", trendStartTime, int(na), 0,
                     100.0, "Super", trendHigh, trendLow, inBuyZone, tr_qualified, "UNQUALIFIED")
                f_draw_label(weeklyMarkerTime, weeklyLow,
                     "TREND START", _tip, label.style_label_up, startColor)

    // ── UPTREND ──────────────────────────────────────────────────────────────
    else if state == STATE_UPTREND
        trendWeeks  += 1
        closesAbove += aboveWeeklyEma ? 1 : 0
        closesBelow += aboveWeeklyEma ? 0 : 1
        trendHigh    := math.max(trendHigh, weeklyHigh)
        trendLow     := math.min(trendLow,  weeklyLow)

        currentStrength      := trendWeeks > 0 ? closesAbove / trendWeeks * 100.0 : 0.0
        currentStrengthClass := f_strength_class(currentStrength)

        if na(firstBuyZoneTime) and inBuyZone
            firstBuyZoneTime  := weeklyTime
            firstBuyZonePrice := weeklyClose

        if trendWeeks >= qualificationWeeks and currentStrength >= minStrengthPct and not tr_qualified
            tr_qualified          := true
            qualifiedSignalEmitted := false
            sigTrQualified        := true

        if not na(firstBuyZonePrice) and firstBuyZonePrice > 0
            maxProfitPct := math.max(maxProfitPct,
                 (weeklyHigh - firstBuyZonePrice) / firstBuyZonePrice * 100.0)

        if trendBreak
            _es = trendWeeks > 0 ? closesAbove / trendWeeks * 100.0 : 0.0
            _ec = f_strength_class(_es)
            f_store_trend_at(trendIds, trendStatuses, trendStarts, trendEnds, trendWeeksArr,
                 trendStrengths, trendClasses, trendBuyZones, trendQualified,
                 trendBufferIdx, trendId, "Ended", trendStartTime, weeklyMarkerTime,
                 trendWeeks, _es, _ec, inBuyZone, tr_qualified)
            trendBufferIdx := (trendBufferIdx + 1) % maxStoredTrends

            sigDowntrendStart          := true
            dailyPositiveCrossoverTime := na
            dailyPositiveCrossoverPrice:= na

            if showTrendEnds
                _etip = f_summary_text(trendId, "Ended", trendStartTime, weeklyMarkerTime,
                     trendWeeks, _es, _ec, trendHigh, trendLow, inBuyZone, tr_qualified,
                     tr_qualified ? "QUALIFIED" : "UNQUALIFIED")
                f_draw_label(weeklyMarkerTime, weeklyHigh,
                     "DOWNTREND", _etip, label.style_label_down, endColor)

            state                  := STATE_DOWNTREND
            buySignalEmitted       := false
            dailyCrossoverConfirmed:= false
            momentumSignalEmitted  := false
            momentumEntryPendingLabel     := false
            positiveCrossoverLabelPending := false
            recoveryPositiveCrossoverNote := false
            tm_firstBuyZoneHit     := false

    // ── DOWNTREND ─────────────────────────────────────────────────────────────
    else if state == STATE_DOWNTREND
        if aboveWeeklyEma
            state                  := STATE_RECOVERING
            momentumSignalEmitted  := false
            recoveryPositiveCrossoverNote := false

    // ── RECOVERING ────────────────────────────────────────────────────────────
    else if state == STATE_RECOVERING
        if trendBreak
            state                       := STATE_DOWNTREND
            dailyCrossoverConfirmed     := false
            momentumSignalEmitted       := false
            momentumEntryPendingLabel   := false
            positiveCrossoverLabelPending:= false
            recoveryPositiveCrossoverNote:= false
            dailyPositiveCrossoverTime  := na
            dailyPositiveCrossoverPrice := na
            recoveryConfirmedWeekTime   := na
        else if aboveWeeklyEma and dailyCrossoverConfirmed
            _rst = nz(recoveryConfirmedWeekTime, weeklyMarkerTime)
            trendId    += 1
            state       := STATE_UPTREND
            trendWeeks  := 0
            closesAbove := 0
            closesBelow := 0
            trendStartTime  := _rst
            trendHigh       := weeklyHigh
            trendLow        := weeklyLow
            firstBuyZoneTime  := inBuyZone ? weeklyMarkerTime : na
            firstBuyZonePrice := inBuyZone ? weeklyClose      : na
            maxProfitPct      := 0.0
            buySignalEmitted  := false
            dailyCrossoverConfirmed       := false
            momentumSignalEmitted         := false
            positiveCrossoverLabelPending := false
            recoveryPositiveCrossoverNote := true
            qualifiedSignalEmitted        := tr_qualified
            sigUptrendStart               := true
            tm_firstBuyZoneHit            := false

            if showTrendStarts
                _rx  = timeframe.isweekly ? _rst : nz(dailyPositiveCrossoverTime, weeklyMarkerTime)
                _ry  = timeframe.isweekly ? weeklyLow : nz(dailyPositiveCrossoverPrice, weeklyLow)
                _rtp = f_summary_text(trendId, "Started (recovery reset)", trendStartTime,
                     int(na), 0, 100.0, "Super", trendHigh, trendLow, inBuyZone,
                     tr_qualified, "UNQUALIFIED") + f_note_suffix("Positive Crossover")
                f_draw_label(_rx, _ry, "TREND START", _rtp, label.style_label_up, startColor)

            momentumEntryPendingLabel   := false
            dailyPositiveCrossoverTime  := na
            dailyPositiveCrossoverPrice := na
            recoveryConfirmedWeekTime   := na

    if state != prevState
        tableNeedsRebuild := true

// =============================================================================
// SIGNAL LAYER  (daily-resolution)
// =============================================================================
if sigTrQualified and not qualifiedSignalEmitted
    qualifiedSignalEmitted := true
    if showConfirmations
        f_draw_label(weeklyMarkerTime, weeklyLow,
             "TR QUALIFIED", "Trend reached qualification threshold",
             label.style_label_up, startColor)
    tableNeedsRebuild := true

if state == STATE_UPTREND and tr_qualified and newDailyFastSlowCross and not buySignalEmitted
    buySignalEmitted  := true
    tableNeedsRebuild := true

if state == STATE_RECOVERING and tr_qualified and newDailyFastSlowCross and not momentumSignalEmitted
    momentumSignalEmitted := true
    sigMomentumEntry      := true
    momentumEntryPendingLabel := true
    tableNeedsRebuild     := true

if state == STATE_UPTREND and tr_qualified and newWeek and inBuyZone and not inBuyZone[1]
    sigReentry        := true
    tableNeedsRebuild := true

if sigUptrendStart or sigDowntrendStart or sigEmaCrossover
    tableNeedsRebuild := true

if timeframe.isweekly and newWeek and positiveCrossoverLabelPending and not sigUptrendStart
    if showConfirmations
        f_draw_label(weeklyMarkerTime, weeklyLow,
             "Positive Crossover",
             "Daily EMA34 crossed above EMA55 during this week",
             label.style_label_up, confirmationColor)
    positiveCrossoverLabelPending := false

if newWeek and showConfirmations and momentumEntryPendingLabel and
     (state == STATE_RECOVERING or state == STATE_UPTREND)
    f_draw_label(weeklyMarkerTime, weeklyLow,
         "MOMENTUM",
         "Positive Crossover during RECOVERING phase",
         label.style_label_up, color.orange)
    momentumEntryPendingLabel := false

// =============================================================================
// CLASSIFICATION  (lazy / top-level)
// =============================================================================
if state == STATE_RECOVERING or not tr_qualified
    currentClassification := "UNQUALIFIED"
else if state == STATE_UPTREND
    if trendWeeks >= qualificationWeeks
        currentClassification := buySignalEmitted ? "PRIME" : "PRIME_WAITLIST"
    else
        currentClassification := buySignalEmitted ? "MOMENTUM" : "MOMENTUM_WAITLIST"
else
    currentClassification := tr_qualified ? "WATCHING" : "UNQUALIFIED"

if (showSummaryLabels or showTrendTable) and (barstate.islast or newWeek)
    currentStrength      := trendWeeks > 0 ? closesAbove / trendWeeks * 100.0 : 0.0
    currentStrengthClass := f_strength_class(currentStrength)
    _status  = state == STATE_UPTREND ? "Active" : state == STATE_RECOVERING ? "Recovering" : "Watching"
    _sNote   = recoveryPositiveCrossoverNote ? f_note_suffix("Positive Crossover") : ""
    summaryCache := f_summary_text(trendId, _status, trendStartTime, int(na), trendWeeks,
         currentStrength, currentStrengthClass, trendHigh, trendLow, inBuyZone,
         tr_qualified, currentClassification) + _sNote

// =============================================================================
// TRADE MANAGER – ENTRY LOGIC
// =============================================================================
// Gate: STATE_UPTREND, (tr_qualified if required), daily bar inside buy-zone
//       with a green candle, and only the FIRST touch per trend cycle.
// One open trade at a time (tm_inTrade gate).
// =============================================================================
_qualGate    = requireQualified ? tr_qualified : true
_entrySignal = state == STATE_UPTREND
                 and _qualGate
                 and dailyInBuyZone
                 and not tm_firstBuyZoneHit   // first-touch latch
                 and not tm_inTrade           // one-trade gate

if _entrySignal and barstate.isconfirmed
    tm_firstBuyZoneHit := true               // arm the latch
    tm_inTrade         := true
    tm_entryPrice      := close
    tm_targetPrice     := close * (1.0 + tm_targetPct / 100.0)
    tm_slPrice         := close * (1.0 - tm_slPct     / 100.0)
    tm_tslHighest      := close
    tm_tslPrice        := close * (1.0 - tm_tslPct    / 100.0)
    tm_tslArmed        := false
    tm_entryBar        := bar_index

    strategy.entry("Long", strategy.long, comment="BUY ZONE ENTRY")

    if showConfirmations
        label.new(x=bar_index, y=low,
             text="🟢 BUY",
             xloc=xloc.bar_index, yloc=yloc.price,
             style=label.style_label_up,
             color=color.rgb(0, 180, 80),
             textcolor=color.white,
             size=size.small,
             tooltip="Entry: " + str.tostring(close, format.mintick) +
                     "\nTarget: " + str.tostring(tm_targetPrice, format.mintick) +
                     "\nSL: "     + str.tostring(tm_slPrice,     format.mintick) +
                     "\nTSL %: "  + str.tostring(tm_tslPct)      + "%")

// =============================================================================
// TRADE MANAGER – TSL TRACKER  (updates every confirmed bar while in trade)
// =============================================================================
if tm_inTrade and barstate.isconfirmed
    // Track highest close reached since entry
    tm_tslHighest := math.max(tm_tslHighest, close)

    // Arm TSL once profit exceeds tm_tslAct %
    if not tm_tslArmed and close >= tm_entryPrice * (1.0 + tm_tslAct / 100.0)
        tm_tslArmed := true

    // Recalculate trailing stop level
    if tm_tslArmed
        tm_tslPrice := tm_tslHighest * (1.0 - tm_tslPct / 100.0)

// =============================================================================
// TRADE MANAGER – EXIT LOGIC
// =============================================================================
// Priority:  1. Hard SL   2. TSL (if armed)   3. Target
// strategy.exit() handles Target and SL atomically; TSL is managed via
// strategy.close() on the bar where trailing condition is met.
// =============================================================================
if tm_inTrade and barstate.isconfirmed

    // ── 1. Hard Stop Loss ────────────────────────────────────────────────────
    if low <= tm_slPrice
        strategy.close("Long", comment="SL HIT")
        tm_inTrade    := false
        tm_tslArmed   := false

    // ── 2. Trailing Stop (armed, and price closes below TSL) ─────────────────
    else if tm_tslArmed and close <= tm_tslPrice
        strategy.close("Long", comment="TSL HIT")
        tm_inTrade    := false
        tm_tslArmed   := false

    // ── 3. Target ────────────────────────────────────────────────────────────
    else if high >= tm_targetPrice
        strategy.close("Long", comment="TARGET HIT")
        tm_inTrade    := false
        tm_tslArmed   := false

// ── Force-exit when trend structure breaks (downtrend confirmed) ──────────────
if sigDowntrendStart and tm_inTrade
    strategy.close("Long", comment="TREND BREAK EXIT")
    tm_inTrade  := false
    tm_tslArmed := false

// ── Reset TM state when a new trade completes (sync with strategy fills) ──────
if strategy.position_size == 0 and tm_inTrade
    tm_inTrade  := false
    tm_tslArmed := false

// =============================================================================
// SUMMARY LABEL  (current trend)
// =============================================================================
if barstate.islast
    if showSummaryLabels and (state == STATE_UPTREND or state == STATE_RECOVERING)
        if not na(currentTrendLabel)
            label.delete(currentTrendLabel)
        currentTrendLabel := label.new(
             x=time, y=high, text="Current Trend",
             xloc=xloc.bar_time, yloc=yloc.price,
             style=label.style_label_left,
             color=recoveryPositiveCrossoverNote ? confirmationColor :
                   (tr_qualified ? startColor : color.rgb(0,105,200)),
             textcolor=color.white, size=size.small,
             tooltip=summaryCache)
    else if not na(currentTrendLabel)
        label.delete(currentTrendLabel)
        currentTrendLabel := na

// =============================================================================
// TREND TABLE  (7 columns – unchanged from v8)
// =============================================================================
var table trendTable = table.new(f_table_position(tablePositionInput), 7, 22, border_width=1)

if barstate.islast and showTrendTable and tableNeedsRebuild
    table.clear(trendTable, 0, 0, 6, 21)
    _sz      = f_text_size(tableTextSizeInput)
    _headers = array.from("#", "Status", "Start", "End", "Weeks", "Strength", "Class")

    for col = 0 to 6
        table.cell(trendTable, col, 0,
             array.get(_headers, col),
             bgcolor=tableHeaderColor, text_color=tableTextColor, text_size=_sz)

    _actStatusBase = state == STATE_UPTREND     ? (tr_qualified ? "ACTIVE" : "Active") :
                     state == STATE_RECOVERING   ? "Recovering" : "–"
    _actId    = state == STATE_UPTREND or state == STATE_RECOVERING ? str.tostring(trendId) : "–"
    _actStart = state == STATE_UPTREND or state == STATE_RECOVERING ? f_date(trendStartTime) : "–"
    _actWeeks = state == STATE_UPTREND or state == STATE_RECOVERING ? str.tostring(trendWeeks) : "–"
    _actStr   = (state == STATE_UPTREND or state == STATE_RECOVERING) and trendWeeks > 0 ?
                 f_pct(closesAbove / trendWeeks * 100.0) : "–"
    _actCls   = (state == STATE_UPTREND or state == STATE_RECOVERING) and trendWeeks > 0 ?
                 f_strength_class(closesAbove / trendWeeks * 100.0) : "–"

    table.cell(trendTable, 0, 1, _actId,         bgcolor=tableBodyColor, text_color=tableTextColor, text_size=_sz)
    table.cell(trendTable, 1, 1, _actStatusBase, bgcolor=tableBodyColor, text_color=tableTextColor, text_size=_sz)
    table.cell(trendTable, 2, 1, _actStart,      bgcolor=tableBodyColor, text_color=tableTextColor, text_size=_sz)
    table.cell(trendTable, 3, 1, "–",            bgcolor=tableBodyColor, text_color=tableTextColor, text_size=_sz)
    table.cell(trendTable, 4, 1, _actWeeks,      bgcolor=tableBodyColor, text_color=tableTextColor, text_size=_sz)
    table.cell(trendTable, 5, 1, _actStr,        bgcolor=tableBodyColor, text_color=tableTextColor, text_size=_sz)
    table.cell(trendTable, 6, 1, _actCls,        bgcolor=tableBodyColor, text_color=tableTextColor, text_size=_sz)

    for i = 0 to maxStoredTrends - 1
        _id = array.get(trendIds, i)
        if _id > 0
            _row = i + 2
            table.cell(trendTable, 0, _row, str.tostring(_id),                      bgcolor=tableBodyColor, text_color=tableTextColor, text_size=_sz)
            table.cell(trendTable, 1, _row, array.get(trendStatuses,  i),           bgcolor=tableBodyColor, text_color=tableTextColor, text_size=_sz)
            table.cell(trendTable, 2, _row, f_date(array.get(trendStarts,    i)),   bgcolor=tableBodyColor, text_color=tableTextColor, text_size=_sz)
            table.cell(trendTable, 3, _row, f_date(array.get(trendEnds,      i)),   bgcolor=tableBodyColor, text_color=tableTextColor, text_size=_sz)
            table.cell(trendTable, 4, _row, str.tostring(array.get(trendWeeksArr,i)),bgcolor=tableBodyColor, text_color=tableTextColor, text_size=_sz)
            table.cell(trendTable, 5, _row, f_pct(array.get(trendStrengths,  i)),   bgcolor=tableBodyColor, text_color=tableTextColor, text_size=_sz)
            table.cell(trendTable, 6, _row, array.get(trendClasses,   i),           bgcolor=tableBodyColor, text_color=tableTextColor, text_size=_sz)

    tableNeedsRebuild := false

else if barstate.islast and not showTrendTable
    table.clear(trendTable, 0, 0, 6, 21)

// =============================================================================
// TRADE MANAGER STATUS TABLE  (5 columns)
// =============================================================================
var table tmTable = table.new(f_table_position(tmTablePosInput), 2, 8, border_width=1)

if barstate.islast and showTMTable
    _sz = f_text_size(tableTextSizeInput)

    // Header row
    table.cell(tmTable, 0, 0, "TM Field",   bgcolor=tableHeaderColor, text_color=tableTextColor, text_size=_sz)
    table.cell(tmTable, 1, 0, "Value",       bgcolor=tableHeaderColor, text_color=tableTextColor, text_size=_sz)

    _inT = tm_inTrade ? "YES" : "NO"
    _ep  = tm_inTrade ? str.tostring(tm_entryPrice,  format.mintick) : "–"
    _tp  = tm_inTrade ? str.tostring(tm_targetPrice, format.mintick) : "–"
    _sp  = tm_inTrade ? str.tostring(tm_slPrice,     format.mintick) : "–"
    _tsl = tm_inTrade ? (tm_tslArmed ? str.tostring(tm_tslPrice, format.mintick) : "Waiting") : "–"
    _pnl = tm_inTrade and tm_entryPrice > 0 ?
         f_pct((close - tm_entryPrice) / tm_entryPrice * 100.0) : "–"

    _rows = array.from("In Trade", "Entry", "Target", "SL", "TSL", "Open P&L", "State")
    _vals = array.from(_inT, _ep, _tp, _sp, _tsl, _pnl,
                        state == STATE_UPTREND ? "UPTREND" :
                        state == STATE_DOWNTREND ? "DOWNTREND" :
                        state == STATE_RECOVERING ? "RECOVERING" :
                        state == STATE_OBSERVING ? "OBSERVING" : "WARMUP")

    for r = 0 to 6
        table.cell(tmTable, 0, r + 1, array.get(_rows, r),
             bgcolor=tableBodyColor, text_color=tableTextColor, text_size=_sz)
        table.cell(tmTable, 1, r + 1, array.get(_vals, r),
             bgcolor=tableBodyColor, text_color=tableTextColor, text_size=_sz)
    