    "version": "0.2.0",
    "configurations": [

        {
            "name": "TR Scan symbol",
            "type": "debugpy",
            "request": "launch",
            "module": "trend_rider_lib",
            "args": [
                "scan",
                "TIINDIA.NS",
                "--start-date",
                "2017-11-01",
                "--end-date",
                "2025-02-03",
                "--debug-csv"
            ],
        },
        {
            "name": "TR Update symbol",
            "type": "debugpy",
            "request": "launch",
            "module": "trend_rider_lib",
            "args": [
                "update",
                "WINDLAS.NS"
            ],
        },
        {
            "name": "TR Show symbol",
            "type": "debugpy",
            "request": "launch",
            "module": "trend_rider_lib",
            "args": [
                "show",
                "--ticker",
                "SMLMAH.NS"
            ],
        }
    ,
        {
            "name": "TR GUI",
            "type": "debugpy",
            "request": "launch",
            "module": "app.app",
            "console": "integratedTerminal"
        }
    ]
}